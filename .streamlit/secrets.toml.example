# Copy this file to .streamlit/secrets.toml (which is git-ignored) for local
# testing against Postgres, OR paste these contents into the "Secrets" box in
# Streamlit Community Cloud (Manage app -> Settings -> Secrets).
#
# Without this, the app falls back to local JSON files in mind_arena_data/.
# Use your Neon POOLED connection string and keep ?sslmode=require.

DATABASE_URL = "postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
